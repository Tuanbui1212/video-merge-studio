# Copy thành ".env" rồi sửa port / IP nếu cần:
#   copy .env.example .env

FRONTEND_PORT=3003
BACKEND_PORT=8003
DB_PORT=5433

# URL API mà TRÌNH DUYỆT gọi tới backend (phải khớp BACKEND_PORT).
# - Chỉ dev trên cùng máy: http://localhost:8003 hoặc http://127.0.0.1:8003
# - Boss / máy khác trong LAN: http://<IP-LAN-máy-chạy-Docker>:8003
#   Ví dụ: http://192.168.1.26:8003
# Sau khi đổi → build lại frontend:
#   docker compose --env-file .env up -d --build --no-deps --renew-anon-volumes frontend
NEXT_PUBLIC_API_URL=http://localhost:8003

# Dùng khi chạy backend ngoài Docker (trong Docker dùng hostname "db")
DATABASE_URL=postgresql://user:password@localhost:5433/videodb
